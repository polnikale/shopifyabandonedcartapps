---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APPS, SEGMENTS, USE_CASES, description, pageTitle, siteFromHost } from '../content';
const site = siteFromHost();
const path = '';
const title = pageTitle(site, path);
const desc = description(site, path);
const recommended = APPS.filter(a => a.channels.includes(site.channel) || a.channels.includes('marketing')).slice(0,10);
---
<BaseLayout title={title} description={desc} site={site} path="/">
  <section class="relative overflow-hidden bg-[#1c1207] py-20 text-amber-50 md:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_22%,#f59e0b_0,transparent_25%),radial-gradient(circle_at_80%_0%,#ef4444_0,transparent_22%),linear-gradient(135deg,#1c1207,#3b1d06_48%,#111827)] opacity-95"></div>
    <div class="container relative grid gap-12 lg:grid-cols-[1.1fr_.9fr] lg:items-center">
      <div>
        <span class="badge badge-dark">Recovery lab · checkout intent focus</span>
        <h1 class="hero-title mt-6 text-amber-50">Shopify abandoned cart apps for recovering revenue without burning margin</h1>
        <p class="mt-6 max-w-3xl text-xl text-amber-100">{site.heroPromise} This rebuild treats abandoned cart recovery as a controlled experiment: timing, channel choice, incentive logic, checkout context, product consideration, consent, and suppression rules all matter before another discount code is mailed.</p>
        <div class="mt-8 flex flex-wrap gap-3"><a class="btn btn-primary" href="/apps">Compare recovery apps</a><a class="btn btn-secondary" href="/use-cases/abandoned-cart">Open cart playbook</a></div>
      </div>
      <div class="rounded-[2rem] border border-amber-300/20 bg-black/25 p-6 shadow-2xl shadow-black/20 backdrop-blur">
        <div class="text-sm font-black uppercase tracking-[.22em] text-amber-200">Lab protocol</div>
        <ol class="mt-6 space-y-5 text-amber-50">
          <li><strong>Diagnose the drop.</strong><p class="mt-1 text-sm text-amber-100">Separate price hesitation, shipping anxiety, product uncertainty, payment friction, and distraction.</p></li>
          <li><strong>Recover with restraint.</strong><p class="mt-1 text-sm text-amber-100">The best app protects profit by using reminders, proof, assistance, and only targeted incentives.</p></li>
          <li><strong>Measure beyond attribution.</strong><p class="mt-1 text-sm text-amber-100">{site.bestOverallReason}</p></li>
        </ol>
      </div>
    </div>
  </section>

  <section class="container py-16"><div class="mb-8"><span class="badge">Recovery shortlist</span><h2 class="mt-3 text-4xl font-black tracking-tight">Apps to test for abandoned checkout recovery</h2><p class="mt-4 max-w-3xl text-slate-600">The first batch favors tools that can connect Shopify cart and order context with email, SMS, push, segmentation, and margin-aware decision rules.</p></div><div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">{recommended.map((app, i) => <a class="card recovery-card" href={`/apps/${app.slug}`}><div class="text-sm font-black text-amber-800">Test lane {i+1}</div><h3 class="mt-3 text-2xl font-black text-slate-950">{app.name}</h3><p class="mt-3 text-sm text-slate-600">{app.bestFor}</p><p class="mt-5 text-sm font-bold text-slate-900">{app.pricing}</p></a>)}</div></section>

  <section class="bg-white py-16"><div class="container grid gap-10 lg:grid-cols-[.85fr_1.15fr]"><div><span class="badge">Recovery scenarios</span><h2 class="mt-3 text-4xl font-black tracking-tight">Cart abandonment is not one problem.</h2><p class="mt-4 text-slate-600">A shopper who abandoned a replenishment product needs different treatment than a first-time buyer evaluating a high-AOV item. The rebuilt pages break down cart recovery by use case and store type so recommendations can discuss timing, creative, social proof, incentives, and escalation instead of repeating the same generic abandoned cart paragraph.</p></div><div class="grid gap-4 sm:grid-cols-2">{USE_CASES.slice(0,10).map(u=><a class="card" href={`/use-cases/${u.slug}`}><h3 class="font-black text-slate-950">{u.name}</h3><p class="mt-2 text-sm text-slate-600">Recovery implications: {u.job}.</p></a>)}</div></div></section>

  <section class="container py-16"><div class="mb-8"><span class="badge">Merchant contexts</span><h2 class="mt-3 text-4xl font-black tracking-tight">Recovery strategy by store model</h2></div><div class="grid gap-4 md:grid-cols-3">{SEGMENTS.map(s=><a class="card" href={`/for/${s.slug}`}><h3 class="text-xl font-black">{s.name}</h3><p class="mt-2 text-sm text-slate-600">Cart recovery must account for {s.pain}.</p></a>)}</div></section>
</BaseLayout>
