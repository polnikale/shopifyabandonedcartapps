---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('mailchimp')!;
const b = appBySlug('recart')!;
const path = '/compare/mailchimp-vs-recart';
const title = pageTitle(site, 'compare/mailchimp-vs-recart');
const desc = description(site, 'compare/mailchimp-vs-recart');
const faqs = [
  {
    question: 'Mailchimp or Recart for cart recovery?',
    answer: 'Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Choose Recart when Stores focused on cart recovery via mobile channels. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $361 cart (67% margin) and $483 cart (55% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 115m → 36h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$361 full-price $241.87 vs 15% code $205.59 (Δ $36.28).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.… Recart: Recart when abandoned cart recovery is the primary problem and mobile reminders outperform email.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
