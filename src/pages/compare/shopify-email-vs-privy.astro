const path = '/compare/shopify-email-vs-privy';
const title = pageTitle(site, 'compare/shopify-email-vs-privy');
const desc = description(site, 'compare/shopify-email-vs-privy');
const faqs = [
  {
    question: 'Shopify Email or Privy for cart recovery?',
    answer: 'Choose Shopify Email when Shops wanting low-friction email inside Shopify Admin. Choose Privy when Smaller stores needing list capture and basic campaigns fast. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $438 cart (44% margin) and $616 cart (46% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 39m → 32h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$438 full-price $192.72 vs 17% code $159.96 (Δ $32.76).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Shopify Email: Shopify Email works for basic newsletters and sale announcements. Stores focused on lifecycle revenue typically graduate… Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
