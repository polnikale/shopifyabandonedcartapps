import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('brevo')!;
const b = appBySlug('recart')!;
const path = '/compare/brevo-vs-recart';
const title = pageTitle(site, 'compare/brevo-vs-recart');
const desc = description(site, 'compare/brevo-vs-recart');
const faqs = [
  {
    question: 'Brevo or Recart for cart recovery?',
    answer: 'Choose Brevo when Budget-conscious stores needing practical campaigns. Choose Recart when Stores focused on cart recovery via mobile channels. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $345 cart (58% margin) and $377 cart (54% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 113m → 18h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$345 full-price $200.1 vs 13% code $174.09 (Δ $26.01).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.… Recart: Recart when abandoned cart recovery is the primary problem and mobile reminders outperform email.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
