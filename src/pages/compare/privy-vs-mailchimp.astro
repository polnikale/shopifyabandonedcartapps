---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('privy')!;
const b = appBySlug('mailchimp')!;
const path = '/compare/privy-vs-mailchimp';
const title = pageTitle(site, 'compare/privy-vs-mailchimp');
const desc = description(site, 'compare/privy-vs-mailchimp');
const faqs = [
  {
    question: 'Privy or Mailchimp for cart recovery?',
    answer: 'Choose Privy when Smaller stores needing list capture and basic campaigns fast. Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $742 cart (61% margin) and $107 cart (65% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 68m → 37h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$742 full-price $452.62 vs 20% code $362.1 (Δ $90.52).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.… Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
