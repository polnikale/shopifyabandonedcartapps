import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('activecampaign')!;
const b = appBySlug('recart')!;
const path = '/compare/activecampaign-vs-recart';
const title = pageTitle(site, 'compare/activecampaign-vs-recart');
const desc = description(site, 'compare/activecampaign-vs-recart');
const faqs = [
  {
    question: 'ActiveCampaign or Recart for cart recovery?',
    answer: 'Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Choose Recart when Stores focused on cart recovery via mobile channels. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $409 cart (68% margin) and $98 cart (36% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 56m → 18h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$409 full-price $278.12 vs 8% code $255.87 (Δ $22.25).',
  },
  {
    question: 'Who should choose each?',
    answer: 'ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.… Recart: Recart when abandoned cart recovery is the primary problem and mobile reminders outperform email.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
