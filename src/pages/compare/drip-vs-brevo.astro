const path = '/compare/drip-vs-brevo';
const title = pageTitle(site, 'compare/drip-vs-brevo');
const desc = description(site, 'compare/drip-vs-brevo');
const faqs = [
  {
    question: 'Drip or Brevo for cart recovery?',
    answer: 'Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Choose Brevo when Budget-conscious stores needing practical campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $638 cart (35% margin) and $423 cart (67% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 92m → 40h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$638 full-price $223.3 vs 18% code $183.11 (Δ $40.19).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Drip: Drip suits teams that enjoy designing behavior-based journeys and want more control than template-only tools.… Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
