import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('shopify-email')!;
const b = appBySlug('yotpo-email-sms')!;
const path = '/compare/shopify-email-vs-yotpo-email-sms';
const title = pageTitle(site, 'compare/shopify-email-vs-yotpo-email-sms');
const desc = description(site, 'compare/shopify-email-vs-yotpo-email-sms');
const faqs = [
  {
    question: 'Shopify Email or Yotpo Email & SMS for cart recovery?',
    answer: 'Choose Shopify Email when Shops wanting low-friction email inside Shopify Admin. Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $286 cart (45% margin) and $365 cart (35% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 115m → 42h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$286 full-price $128.7 vs 15% code $109.39 (Δ $19.31).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Shopify Email: Shopify Email works for basic newsletters and sale announcements. Stores focused on lifecycle revenue typically graduate… Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
