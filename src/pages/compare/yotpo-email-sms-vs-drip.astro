---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('yotpo-email-sms')!;
const b = appBySlug('drip')!;
const path = '/compare/yotpo-email-sms-vs-drip';
const title = pageTitle(site, 'compare/yotpo-email-sms-vs-drip');
const desc = description(site, 'compare/yotpo-email-sms-vs-drip');
const faqs = [
  {
    question: 'Yotpo Email & SMS or Drip for cart recovery?',
    answer: 'Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $312 cart (71% margin) and $106 cart (69% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 93m → 46h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$312 full-price $221.52 vs 19% code $179.43 (Δ $42.09).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.… Drip: Drip suits teams that enjoy designing behavior-based journeys and want more control than template-only tools.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
