---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('mailchimp')!;
const b = appBySlug('justuno')!;
const path = '/compare/mailchimp-vs-justuno';
const title = pageTitle(site, 'compare/mailchimp-vs-justuno');
const desc = description(site, 'compare/mailchimp-vs-justuno');
const faqs = [
  {
    question: 'Mailchimp or Justuno for cart recovery?',
    answer: 'Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Choose Justuno when Stores needing advanced popups, quizzes, and onsite capture. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $594 cart (62% margin) and $247 cart (58% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 91m → 45h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$594 full-price $368.28 vs 17% code $305.67 (Δ $62.61).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.… Justuno: Justuno strengthens the top of the funnel before campaigns in Klaviyo, Sequenzy, or Omnisend begin.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
