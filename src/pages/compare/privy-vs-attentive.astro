import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('privy')!;
const b = appBySlug('attentive')!;
const path = '/compare/privy-vs-attentive';
const title = pageTitle(site, 'compare/privy-vs-attentive');
const desc = description(site, 'compare/privy-vs-attentive');
const faqs = [
  {
    question: 'Privy or Attentive for cart recovery?',
    answer: 'Choose Privy when Smaller stores needing list capture and basic campaigns fast. Choose Attentive when Larger DTC brands with high SMS volume. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $435 cart (70% margin) and $133 cart (60% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 68m → 27h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$435 full-price $304.5 vs 20% code $243.6 (Δ $60.9).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.… Attentive: Attentive fits brands with traffic economics that justify premium SMS programs and managed growth support.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
