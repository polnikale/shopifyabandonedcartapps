---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('mailchimp')!;
const b = appBySlug('sendlane')!;
const path = '/compare/mailchimp-vs-sendlane';
const title = pageTitle(site, 'compare/mailchimp-vs-sendlane');
const desc = description(site, 'compare/mailchimp-vs-sendlane');
const faqs = [
  {
    question: 'Mailchimp or Sendlane for cart recovery?',
    answer: 'Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Choose Sendlane when DTC brands wanting guided retention automation. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $169 cart (47% margin) and $308 cart (38% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 68m → 33h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$169 full-price $79.43 vs 20% code $63.54 (Δ $15.89).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.… Sendlane: Sendlane fits stores with enough order volume to justify a guided retention platform and migration help.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
