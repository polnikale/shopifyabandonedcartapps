---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('mailchimp')!;
const b = appBySlug('brevo')!;
const path = '/compare/mailchimp-vs-brevo';
const title = pageTitle(site, 'compare/mailchimp-vs-brevo');
const desc = description(site, 'compare/mailchimp-vs-brevo');
const faqs = [
  {
    question: 'Mailchimp or Brevo for cart recovery?',
    answer: 'Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Choose Brevo when Budget-conscious stores needing practical campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $367 cart (46% margin) and $292 cart (38% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 114m → 37h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$367 full-price $168.82 vs 14% code $145.19 (Δ $23.63).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.… Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
