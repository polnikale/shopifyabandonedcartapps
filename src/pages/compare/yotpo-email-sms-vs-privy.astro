---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('yotpo-email-sms')!;
const b = appBySlug('privy')!;
const path = '/compare/yotpo-email-sms-vs-privy';
const title = pageTitle(site, 'compare/yotpo-email-sms-vs-privy');
const desc = description(site, 'compare/yotpo-email-sms-vs-privy');
const faqs = [
  {
    question: 'Yotpo Email & SMS or Privy for cart recovery?',
    answer: 'Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Choose Privy when Smaller stores needing list capture and basic campaigns fast. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $108 cart (54% margin) and $786 cart (43% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 35m → 37h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$108 full-price $58.32 vs 13% code $50.74 (Δ $7.58).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.… Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
