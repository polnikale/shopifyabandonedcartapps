const faqs = [
  {
    question: 'Omnisend or Privy for cart recovery?',
    answer: 'Choose Omnisend when SMB Shopify stores wanting multichannel automation without enterprise complexity. Choose Privy when Smaller stores needing list capture and basic campaigns fast. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $611 cart (69% margin) and $553 cart (33% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 49m → 36h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$611 full-price $421.59 vs 14% code $362.57 (Δ $59.02).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Omnisend: Omnisend fits merchants who need cart recovery, welcome, and post-purchase live in days — not months — and want SMS in t… Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.…',
