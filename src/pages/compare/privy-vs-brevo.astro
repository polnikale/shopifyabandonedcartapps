import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('privy')!;
const b = appBySlug('brevo')!;
const path = '/compare/privy-vs-brevo';
const title = pageTitle(site, 'compare/privy-vs-brevo');
const desc = description(site, 'compare/privy-vs-brevo');
const faqs = [
  {
    question: 'Privy or Brevo for cart recovery?',
    answer: 'Choose Privy when Smaller stores needing list capture and basic campaigns fast. Choose Brevo when Budget-conscious stores needing practical campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $672 cart (53% margin) and $535 cart (63% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 42m → 31h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$672 full-price $356.16 vs 20% code $284.93 (Δ $71.23).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.… Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
