const desc = description(site, 'compare/omnisend-vs-yotpo-email-sms');
const faqs = [
  {
    question: 'Omnisend or Yotpo Email & SMS for cart recovery?',
    answer: 'Choose Omnisend when SMB Shopify stores wanting multichannel automation without enterprise complexity. Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $699 cart (60% margin) and $548 cart (62% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 105m → 38h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$699 full-price $419.4 vs 18% code $343.91 (Δ $75.49).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Omnisend: Omnisend fits merchants who need cart recovery, welcome, and post-purchase live in days — not months — and want SMS in t… Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
