---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('activecampaign')!;
const b = appBySlug('brevo')!;
const path = '/compare/activecampaign-vs-brevo';
const title = pageTitle(site, 'compare/activecampaign-vs-brevo');
const desc = description(site, 'compare/activecampaign-vs-brevo');
const faqs = [
  {
    question: 'ActiveCampaign or Brevo for cart recovery?',
    answer: 'Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Choose Brevo when Budget-conscious stores needing practical campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $73 cart (55% margin) and $342 cart (39% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 93m → 47h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$73 full-price $40.15 vs 19% code $32.52 (Δ $7.63).',
  },
  {
    question: 'Who should choose each?',
    answer: 'ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.… Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
