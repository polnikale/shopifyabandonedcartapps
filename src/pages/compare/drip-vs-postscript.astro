const path = '/compare/drip-vs-postscript';
const title = pageTitle(site, 'compare/drip-vs-postscript');
const desc = description(site, 'compare/drip-vs-postscript');
const faqs = [
  {
    question: 'Drip or Postscript for cart recovery?',
    answer: 'Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $202 cart (36% margin) and $392 cart (54% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 58m → 45h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$202 full-price $72.72 vs 10% code $65.45 (Δ $7.27).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Drip: Drip suits teams that enjoy designing behavior-based journeys and want more control than template-only tools.… Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
