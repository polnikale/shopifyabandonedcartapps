import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('activecampaign')!;
const b = appBySlug('rejoiner')!;
const path = '/compare/activecampaign-vs-rejoiner';
const title = pageTitle(site, 'compare/activecampaign-vs-rejoiner');
const desc = description(site, 'compare/activecampaign-vs-rejoiner');
const faqs = [
  {
    question: 'ActiveCampaign or Rejoiner for cart recovery?',
    answer: 'Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Choose Rejoiner when Brands wanting strategic help, not just software. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $523 cart (39% margin) and $822 cart (65% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 88m → 29h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$523 full-price $203.97 vs 14% code $175.41 (Δ $28.56).',
  },
  {
    question: 'Who should choose each?',
    answer: 'ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.… Rejoiner: Rejoiner for brands that want experts designing, writing, and optimizing lifecycle campaigns alongside software.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
