---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('mailchimp')!;
const b = appBySlug('activecampaign')!;
const path = '/compare/mailchimp-vs-activecampaign';
const title = pageTitle(site, 'compare/mailchimp-vs-activecampaign');
const desc = description(site, 'compare/mailchimp-vs-activecampaign');
const faqs = [
  {
    question: 'Mailchimp or ActiveCampaign for cart recovery?',
    answer: 'Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $390 cart (66% margin) and $367 cart (41% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 36m → 35h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$390 full-price $257.4 vs 14% code $221.36 (Δ $36.04).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.… ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
