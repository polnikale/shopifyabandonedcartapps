const path = '/compare/omnisend-vs-postscript';
const title = pageTitle(site, 'compare/omnisend-vs-postscript');
const desc = description(site, 'compare/omnisend-vs-postscript');
const faqs = [
  {
    question: 'Omnisend or Postscript for cart recovery?',
    answer: 'Choose Omnisend when SMB Shopify stores wanting multichannel automation without enterprise complexity. Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $791 cart (63% margin) and $580 cart (37% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 76m → 29h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$791 full-price $498.33 vs 15% code $423.58 (Δ $74.75).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Omnisend: Omnisend fits merchants who need cart recovery, welcome, and post-purchase live in days — not months — and want SMS in t… Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
