const path = '/compare/activecampaign-vs-aftership-email';
const title = pageTitle(site, 'compare/activecampaign-vs-aftership-email');
const desc = description(site, 'compare/activecampaign-vs-aftership-email');
const faqs = [
  {
    question: 'ActiveCampaign or AfterShip Email for cart recovery?',
    answer: 'Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Choose AfterShip Email when Merchants already using AfterShip for tracking workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $746 cart (65% margin) and $117 cart (63% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 87m → 16h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$746 full-price $484.9 vs 13% code $421.86 (Δ $63.04).',
  },
  {
    question: 'Who should choose each?',
    answer: 'ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.… AfterShip Email: AfterShip Email shines when retention messages depend on delivery, tracking, and returns timing.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
