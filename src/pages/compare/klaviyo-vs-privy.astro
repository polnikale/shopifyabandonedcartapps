const path = '/compare/klaviyo-vs-privy';
const title = pageTitle(site, 'compare/klaviyo-vs-privy');
const desc = description(site, 'compare/klaviyo-vs-privy');
const faqs = [
  {
    question: 'Klaviyo or Privy for cart recovery?',
    answer: 'Choose Klaviyo when Stores needing deep ecommerce segmentation and proven Shopify-native flows. Choose Privy when Smaller stores needing list capture and basic campaigns fast. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $476 cart (40% margin) and $631 cart (43% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 64m → 16h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$476 full-price $190.4 vs 16% code $159.94 (Δ $30.46).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Klaviyo: Klaviyo is the heavyweight when a Shopify store has enough order volume to justify profile-based pricing and wants every… Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
