const b = appBySlug('postscript')!;
const path = '/compare/yotpo-email-sms-vs-postscript';
const title = pageTitle(site, 'compare/yotpo-email-sms-vs-postscript');
const desc = description(site, 'compare/yotpo-email-sms-vs-postscript');
const faqs = [
  {
    question: 'Yotpo Email & SMS or Postscript for cart recovery?',
    answer: 'Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $176 cart (69% margin) and $333 cart (55% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 110m → 36h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$176 full-price $121.44 vs 10% code $109.3 (Δ $12.14).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.… Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
