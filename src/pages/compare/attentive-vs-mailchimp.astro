const path = '/compare/attentive-vs-mailchimp';
const title = pageTitle(site, 'compare/attentive-vs-mailchimp');
const desc = description(site, 'compare/attentive-vs-mailchimp');
const faqs = [
  {
    question: 'Attentive or Mailchimp for cart recovery?',
    answer: 'Choose Attentive when Larger DTC brands with high SMS volume. Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
