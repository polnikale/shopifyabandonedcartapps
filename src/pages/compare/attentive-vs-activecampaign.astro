const path = '/compare/attentive-vs-activecampaign';
const title = pageTitle(site, 'compare/attentive-vs-activecampaign');
const desc = description(site, 'compare/attentive-vs-activecampaign');
const faqs = [
  {
    question: 'Attentive or ActiveCampaign for cart recovery?',
    answer: 'Choose Attentive when Larger DTC brands with high SMS volume. Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
