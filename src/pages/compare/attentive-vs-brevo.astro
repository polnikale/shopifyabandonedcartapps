const path = '/compare/attentive-vs-brevo';
const title = pageTitle(site, 'compare/attentive-vs-brevo');
const desc = description(site, 'compare/attentive-vs-brevo');
const faqs = [
  {
    question: 'Attentive or Brevo for cart recovery?',
    answer: 'Choose Attentive when Larger DTC brands with high SMS volume. Choose Brevo when Budget-conscious stores needing practical campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $163 cart (38% margin) and $485 cart (36% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 101m → 39h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$163 full-price $61.94 vs 14% code $53.27 (Δ $8.67).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Attentive: Attentive fits brands with traffic economics that justify premium SMS programs and managed growth support.… Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
