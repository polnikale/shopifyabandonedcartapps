import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('privy')!;
const b = appBySlug('drip')!;
const path = '/compare/privy-vs-drip';
const title = pageTitle(site, 'compare/privy-vs-drip');
const desc = description(site, 'compare/privy-vs-drip');
const faqs = [
  {
    question: 'Privy or Drip for cart recovery?',
    answer: 'Choose Privy when Smaller stores needing list capture and basic campaigns fast. Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $399 cart (46% margin) and $571 cart (32% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 118m → 36h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$399 full-price $183.54 vs 18% code $150.5 (Δ $33.04).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.… Drip: Drip suits teams that enjoy designing behavior-based journeys and want more control than template-only tools.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
