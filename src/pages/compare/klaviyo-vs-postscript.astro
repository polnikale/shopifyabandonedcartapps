const path = '/compare/klaviyo-vs-postscript';
const title = pageTitle(site, 'compare/klaviyo-vs-postscript');
const desc = description(site, 'compare/klaviyo-vs-postscript');
const faqs = [
  {
    question: 'Klaviyo or Postscript for cart recovery?',
    answer: 'Choose Klaviyo when Stores needing deep ecommerce segmentation and proven Shopify-native flows. Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $759 cart (38% margin) and $236 cart (60% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 109m → 45h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$759 full-price $288.42 vs 9% code $262.46 (Δ $25.96).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Klaviyo: Klaviyo is the heavyweight when a Shopify store has enough order volume to justify profile-based pricing and wants every… Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
