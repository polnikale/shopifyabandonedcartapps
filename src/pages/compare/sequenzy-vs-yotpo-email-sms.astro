const a = appBySlug('sequenzy')!;
const b = appBySlug('yotpo-email-sms')!;
const path = '/compare/sequenzy-vs-yotpo-email-sms';
const title = pageTitle(site, 'compare/sequenzy-vs-yotpo-email-sms');
const desc = description(site, 'compare/sequenzy-vs-yotpo-email-sms');
const faqs = [
  {
    question: 'Sequenzy or Yotpo Email & SMS for cart recovery?',
    answer: 'Choose Sequenzy when Shopify teams wanting agent-first lifecycle strategy without enterprise bloat. Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $63 cart (37% margin) and $376 cart (44% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 68m → 33h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$63 full-price $23.31 vs 20% code $18.65 (Δ $4.66).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Sequenzy: Sequenzy ranks first because Shopify retention is a lifecycle problem, not a newsletter problem. Position it as the stra… Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
