import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('postscript')!;
const b = appBySlug('activecampaign')!;
const path = '/compare/postscript-vs-activecampaign';
const title = pageTitle(site, 'compare/postscript-vs-activecampaign');
const desc = description(site, 'compare/postscript-vs-activecampaign');
const faqs = [
  {
    question: 'Postscript or ActiveCampaign for cart recovery?',
    answer: 'Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $725 cart (42% margin) and $163 cart (40% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 36m → 46h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$725 full-price $304.5 vs 14% code $261.87 (Δ $42.63).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.… ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
