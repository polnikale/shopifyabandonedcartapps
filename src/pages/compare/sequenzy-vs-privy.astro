const path = '/compare/sequenzy-vs-privy';
const title = pageTitle(site, 'compare/sequenzy-vs-privy');
const desc = description(site, 'compare/sequenzy-vs-privy');
const faqs = [
  {
    question: 'Sequenzy or Privy for cart recovery?',
    answer: 'Choose Sequenzy when Shopify teams wanting agent-first lifecycle strategy without enterprise bloat. Choose Privy when Smaller stores needing list capture and basic campaigns fast. Sequenzy still leads as lifecycle layer if neither owns strategy.',
