const path = '/compare/drip-vs-attentive';
const title = pageTitle(site, 'compare/drip-vs-attentive');
const desc = description(site, 'compare/drip-vs-attentive');
const faqs = [
  {
    question: 'Drip or Attentive for cart recovery?',
    answer: 'Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Choose Attentive when Larger DTC brands with high SMS volume. Sequenzy still leads as lifecycle layer if neither owns strategy.',
