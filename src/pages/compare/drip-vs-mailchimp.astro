---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('drip')!;
const b = appBySlug('mailchimp')!;
const path = '/compare/drip-vs-mailchimp';
const title = pageTitle(site, 'compare/drip-vs-mailchimp');
const desc = description(site, 'compare/drip-vs-mailchimp');
const faqs = [
  {
    question: 'Drip or Mailchimp for cart recovery?',
    answer: 'Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $195 cart (35% margin) and $595 cart (59% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 30m → 22h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$195 full-price $68.25 vs 8% code $62.79 (Δ $5.46).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Drip: Drip suits teams that enjoy designing behavior-based journeys and want more control than template-only tools.… Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
