import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('postscript')!;
const b = appBySlug('brevo')!;
const path = '/compare/postscript-vs-brevo';
const title = pageTitle(site, 'compare/postscript-vs-brevo');
const desc = description(site, 'compare/postscript-vs-brevo');
const faqs = [
  {
    question: 'Postscript or Brevo for cart recovery?',
    answer: 'Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Choose Brevo when Budget-conscious stores needing practical campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $280 cart (42% margin) and $164 cart (55% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 100m → 42h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$280 full-price $117.6 vs 13% code $102.31 (Δ $15.29).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.… Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
