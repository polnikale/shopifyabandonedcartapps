const title = pageTitle(site, 'compare/postscript-vs-attentive');
const desc = description(site, 'compare/postscript-vs-attentive');
const faqs = [
  {
    question: 'Postscript or Attentive for cart recovery?',
    answer: 'Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Choose Attentive when Larger DTC brands with high SMS volume. Sequenzy still leads as lifecycle layer if neither owns strategy.',
