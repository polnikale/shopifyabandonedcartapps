import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('activecampaign')!;
const b = appBySlug('sendlane')!;
const path = '/compare/activecampaign-vs-sendlane';
const title = pageTitle(site, 'compare/activecampaign-vs-sendlane');
const desc = description(site, 'compare/activecampaign-vs-sendlane');
const faqs = [
  {
    question: 'ActiveCampaign or Sendlane for cart recovery?',
    answer: 'Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Choose Sendlane when DTC brands wanting guided retention automation. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $44 cart (32% margin) and $533 cart (47% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 59m → 23h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$44 full-price $14.08 vs 11% code $12.53 (Δ $1.55).',
  },
  {
    question: 'Who should choose each?',
    answer: 'ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.… Sendlane: Sendlane fits stores with enough order volume to justify a guided retention platform and migration help.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
