const desc = description(site, 'compare/yotpo-email-sms-vs-attentive');
const faqs = [
  {
    question: 'Yotpo Email & SMS or Attentive for cart recovery?',
    answer: 'Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Choose Attentive when Larger DTC brands with high SMS volume. Sequenzy still leads as lifecycle layer if neither owns strategy.',
