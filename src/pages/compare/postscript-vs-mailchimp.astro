---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('postscript')!;
const b = appBySlug('mailchimp')!;
const path = '/compare/postscript-vs-mailchimp';
const title = pageTitle(site, 'compare/postscript-vs-mailchimp');
const desc = description(site, 'compare/postscript-vs-mailchimp');
const faqs = [
  {
    question: 'Postscript or Mailchimp for cart recovery?',
    answer: 'Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $334 cart (33% margin) and $486 cart (51% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 110m → 48h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$334 full-price $110.22 vs 10% code $99.2 (Δ $11.02).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.… Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
