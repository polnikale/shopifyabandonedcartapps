const path = '/compare/shopify-email-vs-mailchimp';
const title = pageTitle(site, 'compare/shopify-email-vs-mailchimp');
const desc = description(site, 'compare/shopify-email-vs-mailchimp');
const faqs = [
  {
    question: 'Shopify Email or Mailchimp for cart recovery?',
    answer: 'Choose Shopify Email when Shops wanting low-friction email inside Shopify Admin. Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $675 cart (33% margin) and $832 cart (58% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 102m → 38h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$675 full-price $222.75 vs 15% code $189.34 (Δ $33.41).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Shopify Email: Shopify Email works for basic newsletters and sale announcements. Stores focused on lifecycle revenue typically graduate… Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
