---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('yotpo-email-sms')!;
const b = appBySlug('mailchimp')!;
const path = '/compare/yotpo-email-sms-vs-mailchimp';
const title = pageTitle(site, 'compare/yotpo-email-sms-vs-mailchimp');
const desc = description(site, 'compare/yotpo-email-sms-vs-mailchimp');
const faqs = [
  {
    question: 'Yotpo Email & SMS or Mailchimp for cart recovery?',
    answer: 'Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $748 cart (46% margin) and $95 cart (37% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 117m → 27h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$748 full-price $344.08 vs 17% code $285.59 (Δ $58.49).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.… Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
