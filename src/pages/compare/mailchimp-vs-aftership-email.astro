---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('mailchimp')!;
const b = appBySlug('aftership-email')!;
const path = '/compare/mailchimp-vs-aftership-email';
const title = pageTitle(site, 'compare/mailchimp-vs-aftership-email');
const desc = description(site, 'compare/mailchimp-vs-aftership-email');
const faqs = [
  {
    question: 'Mailchimp or AfterShip Email for cart recovery?',
    answer: 'Choose Mailchimp when Teams already on Mailchimp needing Shopify-connected campaigns. Choose AfterShip Email when Merchants already using AfterShip for tracking workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $708 cart (35% margin) and $371 cart (35% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 120m → 46h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$708 full-price $247.8 vs 20% code $198.24 (Δ $49.56).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Mailchimp: Mailchimp works for simple lists and broadcasts. Stores focused on lifecycle revenue usually migrate within a year.… AfterShip Email: AfterShip Email shines when retention messages depend on delivery, tracking, and returns timing.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
