import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('klaviyo')!;
const b = appBySlug('yotpo-email-sms')!;
const path = '/compare/klaviyo-vs-yotpo-email-sms';
const title = pageTitle(site, 'compare/klaviyo-vs-yotpo-email-sms');
const desc = description(site, 'compare/klaviyo-vs-yotpo-email-sms');
const faqs = [
  {
    question: 'Klaviyo or Yotpo Email & SMS for cart recovery?',
    answer: 'Choose Klaviyo when Stores needing deep ecommerce segmentation and proven Shopify-native flows. Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $253 cart (34% margin) and $728 cart (70% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 114m → 34h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$253 full-price $86.02 vs 14% code $73.98 (Δ $12.04).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Klaviyo: Klaviyo is the heavyweight when a Shopify store has enough order volume to justify profile-based pricing and wants every… Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
