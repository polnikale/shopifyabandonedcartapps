import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('privy')!;
const b = appBySlug('postscript')!;
const path = '/compare/privy-vs-postscript';
const title = pageTitle(site, 'compare/privy-vs-postscript');
const desc = description(site, 'compare/privy-vs-postscript');
const faqs = [
  {
    question: 'Privy or Postscript for cart recovery?',
    answer: 'Choose Privy when Smaller stores needing list capture and basic campaigns fast. Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $411 cart (44% margin) and $445 cart (58% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 71m → 30h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$411 full-price $180.84 vs 10% code $162.76 (Δ $18.08).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Privy: Privy solves the top-of-funnel problem: turning traffic into subscribers before advanced lifecycle work begins.… Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
