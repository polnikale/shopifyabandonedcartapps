import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('activecampaign')!;
const b = appBySlug('justuno')!;
const path = '/compare/activecampaign-vs-justuno';
const title = pageTitle(site, 'compare/activecampaign-vs-justuno');
const desc = description(site, 'compare/activecampaign-vs-justuno');
const faqs = [
  {
    question: 'ActiveCampaign or Justuno for cart recovery?',
    answer: 'Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Choose Justuno when Stores needing advanced popups, quizzes, and onsite capture. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $644 cart (63% margin) and $479 cart (37% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 30m → 47h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$644 full-price $405.72 vs 8% code $373.26 (Δ $32.46).',
  },
  {
    question: 'Who should choose each?',
    answer: 'ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.… Justuno: Justuno strengthens the top of the funnel before campaigns in Klaviyo, Sequenzy, or Omnisend begin.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
