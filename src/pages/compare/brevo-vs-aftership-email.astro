const title = pageTitle(site, 'compare/brevo-vs-aftership-email');
const desc = description(site, 'compare/brevo-vs-aftership-email');
const faqs = [
  {
    question: 'Brevo or AfterShip Email for cart recovery?',
    answer: 'Choose Brevo when Budget-conscious stores needing practical campaigns. Choose AfterShip Email when Merchants already using AfterShip for tracking workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $282 cart (32% margin) and $216 cart (55% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 44m → 44h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$282 full-price $90.24 vs 9% code $82.12 (Δ $8.12).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.… AfterShip Email: AfterShip Email shines when retention messages depend on delivery, tracking, and returns timing.…',
