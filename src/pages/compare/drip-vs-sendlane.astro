const path = '/compare/drip-vs-sendlane';
const title = pageTitle(site, 'compare/drip-vs-sendlane');
const desc = description(site, 'compare/drip-vs-sendlane');
const faqs = [
  {
    question: 'Drip or Sendlane for cart recovery?',
    answer: 'Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Choose Sendlane when DTC brands wanting guided retention automation. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $146 cart (39% margin) and $449 cart (50% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 97m → 30h → SMS 3h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$146 full-price $56.94 vs 10% code $51.25 (Δ $5.69).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Drip: Drip suits teams that enjoy designing behavior-based journeys and want more control than template-only tools.… Sendlane: Sendlane fits stores with enough order volume to justify a guided retention platform and migration help.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
