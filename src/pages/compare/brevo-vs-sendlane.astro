const path = '/compare/brevo-vs-sendlane';
const title = pageTitle(site, 'compare/brevo-vs-sendlane');
const desc = description(site, 'compare/brevo-vs-sendlane');
const faqs = [
  {
    question: 'Brevo or Sendlane for cart recovery?',
    answer: 'Choose Brevo when Budget-conscious stores needing practical campaigns. Choose Sendlane when DTC brands wanting guided retention automation. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $323 cart (50% margin) and $508 cart (55% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 30m → 47h → SMS 4h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$323 full-price $161.5 vs 8% code $148.58 (Δ $12.92).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.… Sendlane: Sendlane fits stores with enough order volume to justify a guided retention platform and migration help.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
