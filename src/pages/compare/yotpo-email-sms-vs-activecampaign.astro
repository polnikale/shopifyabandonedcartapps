---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('yotpo-email-sms')!;
const b = appBySlug('activecampaign')!;
const path = '/compare/yotpo-email-sms-vs-activecampaign';
const title = pageTitle(site, 'compare/yotpo-email-sms-vs-activecampaign');
const desc = description(site, 'compare/yotpo-email-sms-vs-activecampaign');
const faqs = [
  {
    question: 'Yotpo Email & SMS or ActiveCampaign for cart recovery?',
    answer: 'Choose Yotpo Email & SMS when Stores using or wanting reviews, loyalty, email, and SMS together. Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $671 cart (40% margin) and $187 cart (37% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 54m → 51h → SMS 6h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$671 full-price $268.4 vs 19% code $217.4 (Δ $51.0).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Yotpo Email & SMS: Yotpo makes sense when retention spans campaigns, reviews, loyalty, and SMS — not email alone.… ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
