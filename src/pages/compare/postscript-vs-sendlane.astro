const path = '/compare/postscript-vs-sendlane';
const title = pageTitle(site, 'compare/postscript-vs-sendlane');
const desc = description(site, 'compare/postscript-vs-sendlane');
const faqs = [
  {
    question: 'Postscript or Sendlane for cart recovery?',
    answer: 'Choose Postscript when Brands treating SMS as a revenue channel with compliance guardrails. Choose Sendlane when DTC brands wanting guided retention automation. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $430 cart (69% margin) and $575 cart (59% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 113m → 36h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$430 full-price $296.7 vs 13% code $258.13 (Δ $38.57).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Postscript: Postscript belongs in the stack when checkout recovery and flash-sale urgency need SMS, not email alone.… Sendlane: Sendlane fits stores with enough order volume to justify a guided retention platform and migration help.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
