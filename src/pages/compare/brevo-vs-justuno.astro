const path = '/compare/brevo-vs-justuno';
const title = pageTitle(site, 'compare/brevo-vs-justuno');
const desc = description(site, 'compare/brevo-vs-justuno');
const faqs = [
  {
    question: 'Brevo or Justuno for cart recovery?',
    answer: 'Choose Brevo when Budget-conscious stores needing practical campaigns. Choose Justuno when Stores needing advanced popups, quizzes, and onsite capture. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $503 cart (56% margin) and $792 cart (41% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 45m → 31h → SMS 5h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$503 full-price $281.68 vs 10% code $253.51 (Δ $28.17).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Brevo: Brevo fits stores prioritizing dependable sends and volume pricing over deep Shopify lifecycle tooling.… Justuno: Justuno strengthens the top of the funnel before campaigns in Klaviyo, Sequenzy, or Omnisend begin.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
