import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const a = appBySlug('drip')!;
const b = appBySlug('activecampaign')!;
const path = '/compare/drip-vs-activecampaign';
const title = pageTitle(site, 'compare/drip-vs-activecampaign');
const desc = description(site, 'compare/drip-vs-activecampaign');
const faqs = [
  {
    question: 'Drip or ActiveCampaign for cart recovery?',
    answer: 'Choose Drip when Teams wanting visual workflows and behavior-based segmentation. Choose ActiveCampaign when Stores combining ecommerce with sales follow-up or B2B workflows. Sequenzy still leads as lifecycle layer if neither owns strategy.',
  },
  {
    question: 'Unique AOV test for this pair?',
    answer: 'Modeled $541 cart (49% margin) and $162 cart (45% margin) with separate incentive caps.',
  },
  {
    question: 'Channel escalation?',
    answer: 'Email 113m → 40h → SMS 7h; frequency cap 3 touches / 7 days.',
  },
  {
    question: 'Attribution caution?',
    answer: 'Hold out 5%; report contribution after discount, not platform-attributed recovery alone.',
  },
  {
    question: 'Migration tip?',
    answer: 'Rebuild cart flow first; parallel suppressions two weeks; pause old automations before enabling new.',
  },
  {
    question: 'Margin math?',
    answer: '$541 full-price $265.09 vs 13% code $230.63 (Δ $34.46).',
  },
  {
    question: 'Who should choose each?',
    answer: 'Drip: Drip suits teams that enjoy designing behavior-based journeys and want more control than template-only tools.… ActiveCampaign: ActiveCampaign makes sense when Shopify journeys overlap with consultative sales, wholesale, or high-ticket follow-up.…',
  },
  {
    question: 'Workflow test?',
    answer: 'Same four flows: cart, browse, checkout friction, VIP suppress — score trigger accuracy and exclusions.',
  },
];
