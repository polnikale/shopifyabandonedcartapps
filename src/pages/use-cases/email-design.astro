  {
    question: 'Exclusions?',
    answer: 'Desktop-only templates; Image-heavy emails without alt text; Tiny tap targets on mobile',
  },
  {
    question: 'Metrics to track?',
    answer: 'Mobile click rate, Image-off rendering quality, Time on email (proxy via clicks), Accessibility complaint rate',
  },
  {
    question: 'Common mistakes?',
    answer: 'Desktop-only preview; Product grids with 6+ items on mobile; No plain-text fallback',
  },
  {
    question: 'Margin math example?',
    answer: '$104 AOV, 52% margin: full-price $54.08 contribution vs $45.97 with 15% code.',
