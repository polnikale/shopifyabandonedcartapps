import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const leaving = appBySlug('justuno')!;
const alt2 = appBySlug('recart')!;
const path = '/alternatives/justuno-alternative';
const title = pageTitle(site, 'alternatives/justuno-alternative');
const desc = description(site, 'alternatives/justuno-alternative');
