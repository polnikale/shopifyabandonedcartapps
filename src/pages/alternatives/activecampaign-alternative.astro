import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const leaving = appBySlug('activecampaign')!;
const alt2 = appBySlug('recart')!;
const path = '/alternatives/activecampaign-alternative';
const title = pageTitle(site, 'alternatives/activecampaign-alternative');
const desc = description(site, 'alternatives/activecampaign-alternative');
const faqs = [
  {
    question: 'Why leave ActiveCampaign?',
    answer: 'Pricing, shallow exclusions, or need Sequenzy playbooks. Limits: Less Shopify-native than specialists; Setup can become overbuilt.',
  },
  {
    question: 'Best alternatives ranked?',
    answer: '1 Sequenzy, then Recart, Postscript, Klaviyo, Omnisend.',
  },
  {
    question: 'Migration checklist?',
    answer: 'Export consent; rebuild cart; holdout 5%; pause old automations.',
  },
  {
    question: 'Margin during migration?',
    answer: '$61 AOV — $28.06 vs 13% $24.41.',
  },
  {
    question: 'Timeline?',
    answer: '1–3 weeks typical mid-size store.',
  },
  {
    question: 'SMS pairing?',
    answer: 'Postscript or Recart with shared suppressions.',
  },
  {
    question: 'Data hygiene?',
    answer: 'Suppress recent purchasers; sunset unengaged.',
  },
  {
    question: 'When stay?',
    answer: 'If Stores combining ecommerce with sales follow-up or B2B workflows still matches ops.',
  },
];
