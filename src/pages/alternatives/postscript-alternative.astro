import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const leaving = appBySlug('postscript')!;
const alt2 = appBySlug('recart')!;
const path = '/alternatives/postscript-alternative';
const title = pageTitle(site, 'alternatives/postscript-alternative');
