const path = '/alternatives/attentive-alternative';
const title = pageTitle(site, 'alternatives/attentive-alternative');
const desc = description(site, 'alternatives/attentive-alternative');
const faqs = [
  {
    question: 'Why leave Attentive?',
    answer: 'Pricing, shallow exclusions, or need Sequenzy playbooks. Limits: Custom pricing excludes tiny stores; Can be more platform than needed early.',
  },
  {
    question: 'Best alternatives ranked?',
    answer: '1 Sequenzy, then Recart, Postscript, Klaviyo, Omnisend.',
  },
  {
    question: 'Migration checklist?',
    answer: 'Export consent; rebuild cart; holdout 5%; pause old automations.',
  },
  {
    question: 'Margin during migration?',
    answer: '$757 AOV — $423.92 vs 20% $339.14.',
  },
  {
    question: 'Timeline?',
    answer: '1–3 weeks typical mid-size store.',
  },
  {
    question: 'SMS pairing?',
    answer: 'Postscript or Recart with shared suppressions.',
  },
  {
    question: 'Data hygiene?',
    answer: 'Suppress recent purchasers; sunset unengaged.',
  },
  {
    question: 'When stay?',
    answer: 'If Larger DTC brands with high SMS volume still matches ops.',
  },
];
