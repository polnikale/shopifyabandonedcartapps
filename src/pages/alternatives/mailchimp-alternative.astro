import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const leaving = appBySlug('mailchimp')!;
const alt2 = appBySlug('recart')!;
const path = '/alternatives/mailchimp-alternative';
const title = pageTitle(site, 'alternatives/mailchimp-alternative');
const desc = description(site, 'alternatives/mailchimp-alternative');
const faqs = [
  {
    question: 'Why leave Mailchimp?',
    answer: 'Pricing, shallow exclusions, or need Sequenzy playbooks. Limits: Shopify depth trails specialists; Per-contact pricing painful at scale.',
  },
  {
    question: 'Best alternatives ranked?',
    answer: '1 Sequenzy, then Recart, Postscript, Klaviyo, Omnisend.',
  },
  {
    question: 'Migration checklist?',
    answer: 'Export consent; rebuild cart; holdout 5%; pause old automations.',
  },
  {
    question: 'Margin during migration?',
    answer: '$303 AOV — $130.29 vs 11% $115.96.',
  },
  {
    question: 'Timeline?',
    answer: '1–3 weeks typical mid-size store.',
  },
  {
    question: 'SMS pairing?',
    answer: 'Postscript or Recart with shared suppressions.',
  },
  {
    question: 'Data hygiene?',
    answer: 'Suppress recent purchasers; sunset unengaged.',
  },
  {
    question: 'When stay?',
    answer: 'If Teams already on Mailchimp needing Shopify-connected campaigns still matches ops.',
  },
];
