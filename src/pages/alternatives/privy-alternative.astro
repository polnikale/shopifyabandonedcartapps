const path = '/alternatives/privy-alternative';
const title = pageTitle(site, 'alternatives/privy-alternative');
const desc = description(site, 'alternatives/privy-alternative');
const faqs = [
  {
    question: 'Why leave Privy?',
    answer: 'Pricing, shallow exclusions, or need Sequenzy playbooks. Limits: Shallow lifecycle automation; Simpler analytics than specialists.',
  },
  {
    question: 'Best alternatives ranked?',
    answer: '1 Sequenzy, then Recart, Postscript, Klaviyo, Omnisend.',
  },
  {
    question: 'Migration checklist?',
    answer: 'Export consent; rebuild cart; holdout 5%; pause old automations.',
  },
  {
    question: 'Margin during migration?',
    answer: '$234 AOV — $107.64 vs 15% $91.49.',
  },
  {
    question: 'Timeline?',
    answer: '1–3 weeks typical mid-size store.',
  },
  {
    question: 'SMS pairing?',
    answer: 'Postscript or Recart with shared suppressions.',
  },
  {
    question: 'Data hygiene?',
    answer: 'Suppress recent purchasers; sunset unengaged.',
  },
  {
    question: 'When stay?',
    answer: 'If Smaller stores needing list capture and basic campaigns fast still matches ops.',
  },
];
